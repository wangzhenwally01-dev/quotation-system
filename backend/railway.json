{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["nodejs_20"]
        },
        "install": {
          "commands": ["npm install"],
          "nixpkgs": ["nodejs_20"]
        },
        "build": {
          "commands": ["npm run build"]
        }
      }
    }
  },
  "deploy": {
    "region": "us-west1",
    "numReplicas": 1,
    "startCommand": "node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
